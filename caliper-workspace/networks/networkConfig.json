{
    "version": "1.0",
    "name": "Caliper test",
    "caliper": {
        "blockchain": "fabric"
    },
    "clients": {
        "creator1@org1.example.com": {
            "client": {
                "credentialStore": {
                    "path": "/tmp/org1",
                    "cryptoStore": {
                        "path": "/tmp/org1"
                    }
                },
                "organization": "Org1",
                "clientPrivateKey": {
                    "path": "../../fabric/fabric-samples/test-network/organizations/peerOrganizations/org1.example.com/users/creator1@org1.example.com/msp/keystore/cd5b3c9d38c65a27f6e412529fe34f8fa19269afe8b5735e85e532ebe84aa283_sk"
                },
                "clientSignedCert": {
                    "path": "../../fabric/fabric-samples/test-network/organizations/peerOrganizations/org1.example.com/users/creator1@org1.example.com/msp/signcerts/cert.pem"
                },
                "connection": {
                    "timeout": {
                        "peer": {
                            "endorser": "30"
                        }
                    }
                }
            }
        }
    },
    "channels": {
        "mychannel": {
            "created": true,
            "orderers": [
                "orderer.example.com"
            ],
            "peers": {
                "peer0.org1.example.com": {
                    "endorsingPeer": true,
                    "chaincodeQuery": true,
                    "ledgerQuery": true,
                    "eventSource": true
                },
                "peer0.org2.example.com": {
                    "endorsingPeer": true,
                    "chaincodeQuery": true,
                    "ledgerQuery": true,
                    "eventSource": true
                }
            },
            "contracts": [
                {
                    "id": "apklist",
                    "version": "v1"
                }
            ]
        }
    },
    "organizations": {
        "Org1": {
            "mspid": "Org1MSP",
            "peers": [
                "peer0.org1.example.com"
            ]
        },
        "Org2": {
            "mspid": "Org2MSP",
            "peers": [
                "peer0.org2.example.com"
            ]
        }
    },
    "orderers": {
        "orderer.example.com": {
            "url": "grpcs://127.0.0.1:7050",
            "tlsCACerts": {
                "path": "../../fabric/fabric-samples/test-network/organizations/ordererOrganizations/example.com/orderers/orderer.example.com/tls/ca.crt"
            },
            "grpcOptions": {
                "ssl-target-name-override": "orderer.example.com",
                "hostnameOverride": "orderer.example.com"
            }
        }
    },
    "peers": {
        "peer0.org1.example.com": {
            "url": "grpcs://127.0.0.1:7051",
            "tlsCACerts": {
                "path": "../../fabric/fabric-samples/test-network/organizations/peerOrganizations/org1.example.com/peers/peer0.org1.example.com/tls/ca.crt"
            },
            "grpcOptions": {
                "ssl-target-name-override": "peer0.org1.example.com",
                "hostnameOverride": "peer0.org1.example.com"
            }
        },
        "peer0.org2.example.com": {
            "url": "grpcs://127.0.0.1:9051",
            "tlsCACerts": {
                "path": "../../fabric/fabric-samples/test-network/organizations/peerOrganizations/org2.example.com/peers/peer0.org2.example.com/tls/ca.crt"
            },
            "grpcOptions": {
                "ssl-target-name-override": "peer0.org2.example.com",
                "hostnameOverride": "peer0.org2.example.com"
            }
        }
    }
}